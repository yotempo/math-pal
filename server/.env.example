# ---- AI providers ----------------------------------------------------------
# Fill in the key(s) for whichever provider(s) you want to use.
# The active provider is chosen in the admin panel (設定 → AI 夥伴引擎).
# The app works without any key — AI chat falls back to built-in hints.

# Claude — get a key at https://platform.claude.com (API billing is separate
# from a claude.ai Pro/Max subscription)
ANTHROPIC_API_KEY=

# Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ChatGPT / OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Local Ollama server (for playing at home, no key needed)
OLLAMA_BASE_URL=http://localhost:11434

# ---- server -----------------------------------------------------------------
PORT=8787
